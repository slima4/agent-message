#!/usr/bin/env python3
# ruff: noqa: E401, E701, E702
from __future__ import annotations

import hashlib, json, os, re, sys, time, unicodedata
from pathlib import Path

__version__ = "1.0.0"

ALIAS_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")


def D() -> Path:
    if env := os.environ.get("AGENT_MESSAGE_DIR"):
        return Path(env)
    state = os.environ.get("XDG_STATE_HOME") or str(Path.home()/".local"/"state")
    return Path(state)/"agent-message"


def _ok(a: str | None) -> str | None:
    return a if a and ALIAS_RE.match(a) else None


def me() -> str:
    p = Path(".agent-message")
    if p.is_file():
        try:
            for ln in p.read_text().splitlines():
                s = _ok(ln.strip())
                if s: return s
        except OSError: pass
    return _ok(Path.cwd().name) or "unknown"


def cid(m: dict) -> str:
    c = {k: m[k] for k in ("ts","from","to","thread","body") if k in m}
    if "body" in c: c["body"] = unicodedata.normalize("NFC", c["body"])
    return hashlib.sha256(json.dumps(c, ensure_ascii=False, sort_keys=True, separators=(",", ":")).encode()).hexdigest()[:16]


def thread_of(body: str, frm: str) -> tuple[str, str]:
    m = re.match(r"\s*\[thread:([^\]]+)\]\s*", body)
    if m: return m.group(1).strip(), body[m.end():]
    first = body.splitlines()[0] if body else ""
    slug = re.sub(r"[^a-z0-9]+", "-", first.lower()).strip("-")[:40] or "msg"
    return f"{time.strftime('%Y-%m-%d', time.gmtime())}-{frm}-{slug}", body


def iter_to(d: Path, who: str):
    seen = set()
    for lf in sorted(d.glob("log-*.jsonl")):
        if lf.is_symlink(): continue
        file_alias = lf.name[4:-6]
        with open(lf) as f:
            for ln in f:
                ln = ln.strip()
                if not ln: continue
                try: m = json.loads(ln)
                except json.JSONDecodeError: continue
                if m.get("from") != file_alias: continue
                if m.get("to") != who: continue
                i = m.get("id") or cid(m)
                if i in seen: continue
                seen.add(i)
                yield i, m


def write(d: Path, frm: str, to: str, thread: str, body: str) -> dict:
    body = unicodedata.normalize("NFC", body)
    rec = {"ts": int(time.time()), "from": frm, "to": to, "thread": thread, "body": body}
    rec = {"id": cid(rec), **rec}
    d.mkdir(parents=True, exist_ok=True)
    fd = os.open(d/f"log-{frm}.jsonl", os.O_WRONLY | os.O_APPEND | os.O_CREAT | os.O_NOFOLLOW, 0o644)
    with os.fdopen(fd, "a") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    return rec


def send(args: list[str]) -> None:
    if not args: sys.exit("usage: send <to>")
    if sys.stdin.isatty():
        sys.exit("send: pipe body via stdin, e.g. echo 'hi' | agent-message-cmd send <to>")
    to = args[0]
    body = sys.stdin.read().rstrip("\n")
    frm = me()
    thread, body = thread_of(body, frm)
    rec = write(D(), frm, to, thread, body)
    print(f"sent {frm}→{to} thread={thread} id={rec['id']}")


def reply(args: list[str]) -> None:
    who = me()
    if sys.stdin.isatty():
        sys.exit("reply: pipe body via stdin, e.g. echo 'lgtm' | agent-message-cmd reply")
    body = sys.stdin.read().rstrip("\n")
    d = D()
    mine = [m for _, m in iter_to(d, who)]
    if not mine: sys.exit("no inbox messages to reply to")
    mine.sort(key=lambda m: m.get("ts", 0))
    last = mine[-1]
    rec = write(d, who, last["from"], last["thread"], body)
    print(f"reply {who}→{last['from']} thread={last['thread']} id={rec['id']}")


def inbox(args: list[str]) -> None:
    mode = args[0] if args else "default"
    if mode not in ("default", "all", "raw"): sys.exit(f"unknown mode: {mode}")
    who = me(); d = D()
    sf = d / f".seen-{who}"
    since, since_ids = 0, set()
    if mode == "default" and sf.exists():
        try:
            c = json.loads(sf.read_text())
            since, since_ids = c.get("ts", 0), set(c.get("ids", []))
        except json.JSONDecodeError: pass
    out = []
    for i, m in iter_to(d, who):
        t = m.get("ts", 0)
        if mode == "default" and (t < since or (t == since and i in since_ids)): continue
        out.append((i, m))
    out.sort(key=lambda x: x[1].get("ts", 0))
    if not out:
        print("no new messages" if mode == "default" else "no messages"); return
    if mode == "raw":
        for _, m in out:
            print(json.dumps(m, ensure_ascii=False))
        return
    for _, m in out:
        t = time.strftime("%m-%d %H:%M", time.localtime(m.get("ts", 0)))
        body = m.get("body") or ""
        first = body.splitlines()[0][:80] if body else ""
        print(f"[{t}] from={m['from']} thread={m['thread']}: {first}")
    if mode == "default":
        nm = max(m.get("ts", 0) for _, m in out)
        nids = [i for i, m in out if m.get("ts", 0) == nm]
        if nm == since: nids = sorted(since_ids | set(nids))
        tmp = sf.with_suffix(".tmp")
        tmp.write_text(json.dumps({"ts": nm, "ids": list(nids)}))
        os.replace(str(tmp), str(sf))
    senders = sorted({m["from"] for _, m in out})
    print(f"{len(out)} new from: {', '.join(senders)}")


OPS = {"send": send, "inbox": inbox, "reply": reply}

if __name__ == "__main__":
    if len(sys.argv) >= 2 and sys.argv[1] in ("--version", "-V"):
        print(f"agent-message {__version__} (SAMP v1)")
        sys.exit(0)
    if len(sys.argv) < 2 or sys.argv[1] not in OPS:
        sys.exit(f"usage: {Path(sys.argv[0]).name} {{{'|'.join(OPS)}}} [args]  (--version)")
    OPS[sys.argv[1]](sys.argv[2:])
